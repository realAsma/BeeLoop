#!/usr/bin/env bash
set -euo pipefail

BEEBOT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"
GUEST_WORKSPACE="$BEEBOT_ROOT/workspaces/workspace_guest"
GUEST_CODEX_HOME="$GUEST_WORKSPACE/codex_home_guest"
GUEST_CLAUDE_HOME="$GUEST_WORKSPACE/claude_home_guest"

source "$BEEBOT_ROOT/bees/args.sh"

usage() {
  cat <<'EOF'
usage: guest_bee [request-body]

Runs a restricted public-safe bee.
Request comes from stdin or one request-body argument.
EOF
}

engine="codex"

handle_arg() {
  case "$1" in
  engine) engine="$2" ;;
  *) unknown_arg "$1" ;;
  esac
}

parse_request "$@"

mkdir -p "$GUEST_WORKSPACE" "$GUEST_CODEX_HOME" "$GUEST_CLAUDE_HOME"
ln -sfn AGENTS.md "$GUEST_WORKSPACE/CLAUDE.md"

cd "$GUEST_WORKSPACE"

case "$engine" in
codex)
  exec env CODEX_HOME="$GUEST_CODEX_HOME" codex exec \
    --sandbox read-only \
    --skip-git-repo-check \
    -c 'project_root_markers=[]' \
    -- "$prompt"
  ;;
claude)
  claude_settings="$(printf '{"claudeMdExcludes":["%s/CLAUDE.md"]}' "$BEEBOT_ROOT")"
  exec env CLAUDE_CONFIG_DIR="$GUEST_CLAUDE_HOME" claude -p "$prompt" \
    --permission-mode plan \
    --settings "$claude_settings"
  ;;
*)
  printf 'guest_bee: unknown engine %s\n' "$engine" >&2
  exit 2
  ;;
esac
