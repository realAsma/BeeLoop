#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
BEEBOT_ROOT="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd -P)"

source "$BEEBOT_ROOT/bees/args.sh"

usage() {
  cat <<'EOF'
usage: worker_bee

Runs a workspace-scoped worker.
Optional headers: engine=codex|claude, mode=default|yolo, final_file=PATH, log_file=PATH.
Reads the request body from stdin.
Prints only the worker final answer to stdout; writes worker transcript to log_file.
EOF
}

engine="codex"
mode="default"
workspace=""
final_file=""
log_file=""

handle_arg() {
  case "$1" in
  engine) engine="$2" ;;
  mode) mode="$2" ;;
  workspace) workspace="$2" ;;
  final_file) final_file="$2" ;;
  log_file) log_file="$2" ;;
  *) unknown_arg "$1" ;;
  esac
}

parse_request "$@"

[[ -n "$workspace" ]] || {
  printf 'worker_bee: missing workspace=PATH\n' >&2
  exit 2
}

if ! workspace_dir="$(cd "$workspace" 2>/dev/null && pwd -P)"; then
  printf 'worker_bee: invalid workspace %s\n' "$workspace" >&2
  exit 2
fi
cd "$workspace_dir"

[[ -n "$prompt" ]] || {
  printf 'worker_bee: missing prompt\n' >&2
  exit 2
}

case "$mode" in
""|default)
  codex_sandbox="workspace-write"
  claude_permission_mode="acceptEdits"
  ;;
yolo)
  codex_sandbox="danger-full-access"
  claude_permission_mode="bypassPermissions"
  ;;
*)
  printf 'worker_bee: unknown mode %s\n' "$mode" >&2
  exit 2
  ;;
esac

run_dir="$BEEBOT_ROOT/logs/worker_bee"
mkdir -p "$run_dir"
run_id="$(date -u +%Y%m%dT%H%M%SZ)-$$"
final_file="${final_file:-$run_dir/$run_id.final.md}"
log_file="${log_file:-$run_dir/$run_id.log}"

run_status=0

case "$engine" in
codex)
  codex exec \
    --output-last-message "$final_file" \
    --sandbox "$codex_sandbox" \
    --skip-git-repo-check \
    -c 'project_root_markers=[]' \
    -- "$prompt" >"$log_file" 2>&1 || run_status=$?
  ;;
claude)
  claude_settings="$(printf '{"claudeMdExcludes":["%s/CLAUDE.md"]}' "$BEEBOT_ROOT")"
  claude -p "$prompt" --permission-mode "$claude_permission_mode" --settings "$claude_settings" \
    >"$final_file" 2>"$log_file" || run_status=$?
  ;;
*)
  printf 'worker_bee: unknown engine %s\n' "$engine" >&2
  exit 2
  ;;
esac

if ((run_status != 0)); then
  printf 'worker_bee: %s failed with exit %s; log: %s\n' "$engine" "$run_status" "$log_file" >&2
  tail -n 40 "$log_file" >&2 || true
  exit "$run_status"
fi

[[ -s "$final_file" ]] || {
  printf 'worker_bee: missing final output: %s\n' "$final_file" >&2
  exit 1
}

cat "$final_file"
