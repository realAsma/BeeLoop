#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
BEEBOT_ROOT="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd -P)"

source "$BEEBOT_ROOT/bees/args.sh"

usage() {
  cat <<'EOF'
usage: beebot

Runs the owner-facing BeeBot.
Reads the request body from stdin.
EOF
}

engine="${BEEBOT_ENGINE:-codex}"

handle_arg() {
  case "$1" in
  engine) engine="$2" ;;
  *) unknown_arg "$1" ;;
  esac
}

parse_request "$@"

if [[ -z "$prompt" && -t 0 ]]; then
  case "$engine" in
  codex)
    exec codex \
      --sandbox danger-full-access \
      --dangerously-bypass-approvals-and-sandbox \
      -C "$BEEBOT_ROOT"
    ;;
  claude)
    cd "$BEEBOT_ROOT"
    exec claude --permission-mode bypassPermissions
    ;;
  *)
    printf 'beebot: unknown engine %s\n' "$engine" >&2
    exit 2
    ;;
  esac
fi

case "$engine" in
codex)
  exec codex exec \
    --sandbox danger-full-access \
    --dangerously-bypass-approvals-and-sandbox \
    --skip-git-repo-check \
    -C "$BEEBOT_ROOT" \
    -- "$prompt"
  ;;
claude)
  cd "$BEEBOT_ROOT"
  exec claude -p "$prompt" --permission-mode bypassPermissions
  ;;
*)
  printf 'beebot: unknown engine %s\n' "$engine" >&2
  exit 2
  ;;
esac
