#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
BEEBOT_ROOT="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd -P)"

if (($# == 0)) && [[ -t 0 ]]; then
  exec codex \
    --sandbox danger-full-access \
    --dangerously-bypass-approvals-and-sandbox \
    -C "$BEEBOT_ROOT"
fi

if (($# > 0)); then
  prompt="$*"
else
  prompt="$(cat)"
fi

exec codex exec \
  --sandbox danger-full-access \
  --dangerously-bypass-approvals-and-sandbox \
  --skip-git-repo-check \
  -C "$BEEBOT_ROOT" \
  -- "$prompt"
