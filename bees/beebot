#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
BEEBOT_ROOT="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd -P)"

engine="${BEEBOT_ENGINE:-codex}"

if (($# == 0)) && [[ -t 0 ]]; then
  case "$engine" in
  codex)
    exec codex \
      --sandbox danger-full-access \
      --dangerously-bypass-approvals-and-sandbox \
      -C "$BEEBOT_ROOT"
    ;;
  claude)
    cd "$BEEBOT_ROOT"
    exec claude --permission-mode bypassPermissions
    ;;
  *)
    printf 'beebot: unknown BEEBOT_ENGINE %s (expected codex or claude)\n' "$engine" >&2
    exit 2
    ;;
  esac
fi

if (($# > 0)); then
  prompt="$*"
else
  prompt="$(cat)"
fi

case "$engine" in
codex)
  exec codex exec \
    --sandbox danger-full-access \
    --dangerously-bypass-approvals-and-sandbox \
    --skip-git-repo-check \
    -C "$BEEBOT_ROOT" \
    -- "$prompt"
  ;;
claude)
  cd "$BEEBOT_ROOT"
  exec claude -p "$prompt" --permission-mode bypassPermissions
  ;;
*)
  printf 'beebot: unknown BEEBOT_ENGINE %s (expected codex or claude)\n' "$engine" >&2
  exit 2
  ;;
esac
