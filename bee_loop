#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
mkdir -p "$ROOT/bees" "$ROOT/inputs.d" "$ROOT/logs"
shopt -s nullglob

while true; do
  for input in "$ROOT/inputs.d"/*; do
    input_name="$(basename "$input")"
    if msg="$("$input")"; then
      :
    else
      printf 'bee_loop: input failed: %s\n' "$input_name" >&2
      continue
    fi
    [[ -n "$msg" ]] || continue
    first_line="${msg%%$'\n'*}"
    bee_name="${first_line#bee=}"
    body="${msg#*$'\n\n'}"

    printf '[%s] bee_loop: input detected: %s bee=%s\n' \
      "$(date -Is)" "$input_name" "$bee_name" | tee -a "$ROOT/logs/bee_loop.log"
    printf '%s' "$body" | "$ROOT/bees/$bee_name" \
      >>"$ROOT/logs/bee_loop.$bee_name.log" 2>&1 &
  done
  sleep "${BEELOOP_INPUT_INTERVAL:-1}"
done
